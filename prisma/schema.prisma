generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuarios y roles
enum Role {
  ADMIN
  INSTITUTION
  PATIENT
  EXECUTIVE
  OPERATOR
  ANALYST
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  institution Institution?
  orders      Order[]
}

// Instituciones (clínicas)
model Institution {
  id   Int    @id @default(autoincrement())
  name String
  rut  String @unique

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

// Productos
model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  category String
  code        String  @unique

  originalPrice   Float
  offerPercentage Float @default(0)

  rating      Float @default(0)
  ratingCount Int   @default(0)

  stocks Int @default(0)

  images ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
}

model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Órdenes / ventas
enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PREPARATION
  SHIPPED
  DELIVERED
}

model Order {
  id     Int         @id @default(autoincrement())
  total  Float
  status OrderStatus @default(PENDING)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items OrderItem[]

  payment  Payment?
  tracking Tracking?

  createdAt DateTime @default(now())
}

model OrderItem {
  id Int @id @default(autoincrement())

  quantity Int
  price    Float

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

// Pagos
enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

model Payment {
  id            Int           @id @default(autoincrement())
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id])
}

// Logística / tracking
model Tracking {
  id      Int     @id @default(autoincrement())
  code    String  @unique
  carrier String?
  status  String?

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id])
}
